{
  "name": "@nexus/secrets",
  "version": "0.0.0",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": { "types": "./dist/index.d.ts", "import": "./dist/index.js" }
  },
  "files": ["dist", "src/actions"],
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "@nexus/types": "workspace:*",
    "viem": "^2.21.55"
  },
  "peerDependencies": {
    "@lit-protocol/constants": "^7.0.0",
    "@lit-protocol/encryption": "^7.0.0",
    "@lit-protocol/lit-node-client": "^7.0.0"
  },
  "peerDependenciesMeta": {
    "@lit-protocol/constants": { "optional": true },
    "@lit-protocol/encryption": { "optional": true },
    "@lit-protocol/lit-node-client": { "optional": true }
  },
  "devDependencies": {
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
