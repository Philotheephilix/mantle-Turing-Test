{
  "name": "nexus",
  "private": true,
  "version": "0.0.0",
  "description": "Fully onchain turn-based game engine SDK for Mantle — one ERC-7710 delegation powers gasless gameplay and x402 monetization.",
  "type": "module",
  "packageManager": "pnpm@11.0.9",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "turbo run build",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "contracts:build": "pnpm --filter @nexus/contracts build",
    "contracts:test": "pnpm --filter @nexus/contracts test",
    "clean": "turbo run clean && rm -rf node_modules"
  },
  "devDependencies": {
    "@biomejs/biome": "1.9.4",
    "@types/node": "^22.10.0",
    "tsup": "^8.3.5",
    "turbo": "^2.3.3",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
