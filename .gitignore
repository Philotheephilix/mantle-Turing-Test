node_modules/
dist/
out/
cache/
coverage/
.turbo/
*.tsbuildinfo

# env / secrets — NEVER commit
.env
.env.*
!.env.example

# foundry
packages/contracts/out/
packages/contracts/cache/
packages/contracts/broadcast/**/dry-run/
# forge dependencies — fetched via `pnpm --filter @nexus/contracts setup` (forge install)
packages/contracts/lib/

# logs
*.log
.DS_Store

# deployment artifacts with addresses are kept, but local runs are not
scripts/.live-state.json

# local deployment address dumps
packages/contracts/deployments/*.json

# example local env (hardcoded testnet key — never commit)
examples/**/.env.local
examples/.shared-env.local
examples/**/node_modules/
examples/**/.next/
examples/**/test-results/
examples/**/playwright-report/

# example runtime secrets (generated player keys) — never commit
examples/**/players.local.json
examples/**/.players.json
examples/**/playwright/.auth/
examples/**/.pw-user-data/
examples/**/out/
examples/**/cache/
examples/**/broadcast/
examples/**/.last-run.json
