# ── Nexus environment ──────────────────────────────────────────────
# Copy to .env and fill in. NEVER commit .env.

# Funded deployer/player key for LIVE tests (Mantle Sepolia). Required.
PRIVATE_KEY=0x...

# A second funded key to simulate a second player in live game tests. Optional but
# recommended (full multi-player flow). If absent, single-player paths still run.
PRIVATE_KEY_2=0x...

# ── Chain / RPC ────────────────────────────────────────────────────
# Mantle Sepolia is the default test target. Mantle mainnet only when a feature is
# mainnet-only (the SDK selects it automatically and warns).
CHAIN=mantle-sepolia                       # mantle-sepolia | mantle
MANTLE_SEPOLIA_RPC_URL=https://rpc.sepolia.mantle.xyz
MANTLE_RPC_URL=https://rpc.mantle.xyz

# ── Deployed contract addresses (filled by scripts/deploy after first deploy) ──
WORLD_ADDRESS=
DELEGATION_MANAGER_ADDRESS=               # canonical MetaMask DelegationManager on the chain

# ── Third-party services (optional — unlock specific paths) ─────────
# 1Shot relayer. If unset, the SDK uses the live DirectRelayer (self-relay) instead.
ONESHOT_API_KEY=
ONESHOT_API_SECRET=
ONESHOT_ENDPOINT=https://relayer.1shotapi.com
ONESHOT_WEBHOOK_URL=

# Lit Protocol network for sealed state. datil-test is free/public.
LIT_NETWORK=datil-test                    # datil-test | datil

# Chainlink VRF (Mantle). If unset, only the onchain commit-reveal / fast tiers are live.
VRF_COORDINATOR=
VRF_SUBSCRIPTION_ID=
VRF_KEY_HASH=

# ── Backend ────────────────────────────────────────────────────────
PORT=8080
DATABASE_URL=                             # Postgres for the indexer (prod). Dev uses sqlite/memory.
REDIS_URL=                                # session/webhook store (prod). Dev uses memory.
